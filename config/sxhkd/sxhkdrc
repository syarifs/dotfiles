super + Return
	alacritty

super + @space
    rofi -show drun -icon-theme "Numix Arc" -show-icons	-columns 3

super + Escape
	pkill -USR1 -x sxhkd

super + alt + q
	~/.local/bin/logout

super + m
    ~/.local/bin/mpdc

super + n
    networkmanager_dmenu 

super + s
    ~/.local/bin/webserver

@Print
    ~/.local/bin/screenshot

super + ctrl + Right
    bspc desktop next.local -f

super + ctrl + Left
    bspc desktop prev.local -f

super + alt + r
    bspc wm -r

super + e
    pcmanfm

super + b
    min

super + q
	bspc node -c

super + shift + {1-9}
    bspc node -d '^{1-9}' --follow

super + {1-9}
   bspc desktop -f '^{1-9}'

super + {t,shift + t,s,f}
	bspc node -t {tiled,pseudo_tiled,floating,fullscreen}

super + Left
    bspc node -f west

super + Right
    bspc node -f east

super + Up
    bspc node -f north

super + Down
    bspc node -f south

XF86MonBrightnessUp
    xbacklight -inc 5% 

XF86MonBrightnessDown
    xbacklight -dec 5% 

XF86AudioRaiseVolume
    amixer sset Master 5%+ 

XF86AudioLowerVolume
    amixer sset Master 5%- 

XF86AudioMute
    amixer sset Master toggle

XF86AudioNext
    mpc next

XF86AudioPrev
    mpc prev

XF86AudioPlay
    mpc toggle

XF86AudioStop
    mpc stop

super + p
    ~/.local/bin/projector

ctrl + Escape
    killall compton; notify-send "Compton Killed"
    
