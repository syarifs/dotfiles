{
  "coc.preferences.formatOnSaveFiletypes": [
    "css",
    "markdown",
    "graphql",
    "html",
    "yaml",
    "json",
    "python",
    "php"
  ],

 "javascript.suggestionActions.enabled": false,
 "eslint.quiet": true,

  "tailwindCSS.trace.server": "verbose",

  "coc.source.tag.enable": true,
  "intelephense.runtime": "node",

  "python.linting.pylintArgs": ["--generate-members", "--extension-pkg-whitelist=cv2"],
  "python.linting.enabled": true,
  "python.linting.pylintEnabled": true,
  "snippets.ultisnips.directories": [
    "UltiSnips",
    "~/.config/nvim/utils/snips"
  ],
  "python.autoComplete.extraPaths": [
    "${env:SPARK_HOME}/python",
    "${env:SPARK_HOME}/python/pyspark"
  ]
}
