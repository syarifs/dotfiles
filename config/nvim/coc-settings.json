{
  "coc.preferences.formatOnSaveFiletypes": [
    "css",
    "markdown",
    "javascript",
    "graphql",
    "vue",
    "html",
    "yaml",
    "json",
    "python",
    "php"
  ],

  // python config
  "python.linting.enabled": true,
  "python.linting.pylintEnabled": true,

  "coc.source.tag.enable": true,

  "snippets.ultisnips.directories": ["UltiSnips", "~/.config/nvim/utils/snips"]
}
