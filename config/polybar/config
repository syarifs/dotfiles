[colors]
background = #af112c11
underline1 = #c49572
underline2 = #865e5e
danger = #A22C2C
panel_bg = #af000000

[bar/mybar]
# font settings
font-0 = "3270Narrow Nerd Font:size=12;3"

# panel setup
width = 100%
height = 16px
line-size = 3px
offset-x = 0
offset-y = 0
wm-restack = bspwm
background = ${colors.panel_bg}
separator = "|"

# modules position 
modules-left = bspwm title
modules-right = pulseaudio temperature memory network battery date 


[module/bspwm]
type = internal/bspwm
inline-mode = false

label-empty = " %name% "

label-focused = " %name% "
label-focused-background = ${colors.background}
label-focused-underline = ${colors.underline1}

label-occupied = " %name% "
label-occupied-underline = ${colors.underline2}
label-occupied-foreground = ${colors.underline2}


[module/date]
type = internal/date
date = "   %Y-%m-%d "
date-alt = "   %H:%M "

[module/battery]
type = internal/battery
battery = BAT0

label-discharging = " %percentage%% "
label-charging = " %percentage%% "
label-full = "  %percentage%"

animation-charging-0 = "  "
animation-charging-1 = "  "
animation-charging-2 = "  "
animation-charging-3 = "  "
animation-charging-4 = "  "

ramp-capacity-0 = "  "
ramp-capacity-1 = "  "
ramp-capacity-2 = "  "
ramp-capacity-3 = "  "
ramp-capacity-4 = "  "

format-discharging = <ramp-capacity> <label-discharging>
format-charging = <animation-charging> <label-charging>

[module/memory]
type = internal/memory
label = "  %gb_used% / %gb_total% "

[module/network]
type = internal/network
interface = wlp3s0

label-connected = "%{A:networkmanager_dmenu&:} 直  %essid% %{A}"
label-disconnected = "%{A:networkmanager_dmenu&:} 睊  Disconnected %{A}"

[module/temperature]
type = internal/temperature

label = "  %temperature-c% "
warn-temperature = 60

label-warn = "  %temperature-c% "
label-warn-foreground = ${colors.danger}

[module/pulseaudio]
type = internal/pulseaudio
label-volume = " %percentage%% "
label-muted = " ﱝ muted "
label-muted-foreground = #666

ramp-volume-0 = 奄
ramp-volume-1 = 奔
ramp-volume-2 = 墳

format-volume = <ramp-volume> <label-volume>

[module/title]
type = internal/xwindow
label = " %title% "
label-maxlen = 30
