#!/bin/sh

THEME="~/.config/rofi/config.rasi"

if [ "$1" = "-c" ]; then
  THEME="$2"
fi

MENU=$(rofi -sep '|' -theme $THEME -p 'Exit System' -width 20 -lines 3 -dmenu <<< "’Īé Logout|’źÆ Restart|’żż Shutdown")

case $MENU in
    *Logout) pkill -KILL -u $USER ;;
    *Restart) systemctl reboot ;;
    *Shutdown) systemctl -i poweroff
esac
